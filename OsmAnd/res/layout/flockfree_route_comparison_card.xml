<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:background="?attr/card_and_list_background_basic"
	android:orientation="vertical">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:paddingStart="@dimen/content_padding"
		android:paddingTop="@dimen/content_padding"
		android:paddingEnd="@dimen/content_padding"
		android:paddingBottom="@dimen/content_padding">

		<TextView
			android:id="@+id/flockfree_route_comparison_title"
			style="@style/TitleStyle"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/flockfree_route_comparison_title"
			android:textStyle="bold" />

		<LinearLayout
			android:id="@+id/flockfree_route_comparison_options"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="@dimen/content_padding_small"
			android:orientation="horizontal">

			<LinearLayout
				android:id="@+id/flockfree_route_fastest_card"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:minHeight="112dp"
				android:orientation="vertical"
				android:padding="12dp">

				<TextView
					android:id="@+id/flockfree_route_fastest_title"
					style="@style/TitleStyle"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:maxLines="1"
					android:text="@string/flockfree_route_preview_fastest"
					android:textStyle="bold" />

				<TextView
					android:id="@+id/flockfree_route_fastest_distance_time"
					style="@style/DescStyle"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="8dp"
					android:maxLines="2"
					tools:text="6.1 mi • 9 min" />

				<TextView
					android:id="@+id/flockfree_route_fastest_cameras"
					style="@style/DescStyle"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="6dp"
					android:maxLines="1"
					tools:text="6 cameras" />

			</LinearLayout>

			<Space
				android:layout_width="12dp"
				android:layout_height="1dp" />

			<LinearLayout
				android:id="@+id/flockfree_route_privacy_card"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:minHeight="112dp"
				android:orientation="vertical"
				android:padding="12dp">

				<TextView
					android:id="@+id/flockfree_route_privacy_title"
					style="@style/TitleStyle"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:maxLines="1"
					android:text="@string/flockfree_route_comparison_privacy"
					android:textStyle="bold" />

				<TextView
					android:id="@+id/flockfree_route_privacy_distance_time"
					style="@style/DescStyle"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="8dp"
					android:maxLines="2"
					tools:text="7.7 mi • 12 min" />

				<TextView
					android:id="@+id/flockfree_route_privacy_cameras"
					style="@style/DescStyle"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="6dp"
					android:maxLines="1"
					tools:text="0 cameras" />

				<TextView
					android:id="@+id/flockfree_route_privacy_active"
					style="@style/DescStyle"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="6dp"
					android:maxLines="1"
					android:text="@string/flockfree_route_comparison_active_route" />

			</LinearLayout>

		</LinearLayout>

		<LinearLayout
			android:id="@+id/flockfree_route_comparison_summary"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="@dimen/content_padding_small"
			android:gravity="center_vertical"
			android:minHeight="56dp"
			android:orientation="vertical"
			android:paddingStart="12dp"
			android:paddingTop="8dp"
			android:paddingEnd="12dp"
			android:paddingBottom="8dp">

			<TextView
				android:id="@+id/flockfree_route_comparison_summary_text"
				style="@style/DescStyle"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:maxLines="2"
				android:textStyle="bold"
				tools:text="Avoids 6 cameras (100% fewer)" />

			<TextView
				android:id="@+id/flockfree_route_comparison_summary_meta"
				style="@style/DescStyle"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:maxLines="1"
				tools:text="+3 min • +25% distance" />

		</LinearLayout>

	</LinearLayout>

	<include
		android:id="@+id/shadow"
		layout="@layout/card_bottom_divider"
		android:visibility="visible" />

</LinearLayout>
