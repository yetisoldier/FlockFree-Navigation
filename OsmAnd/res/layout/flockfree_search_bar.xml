<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="280dp"
	android:layout_height="48dp"
	android:background="@drawable/bg_flockfree_search_bar"
	android:clickable="true"
	android:clipToOutline="true"
	android:elevation="4dp"
	android:focusable="true"
	android:gravity="center_vertical"
	android:orientation="horizontal"
	android:paddingStart="16dp"
	android:paddingEnd="18dp">

	<ImageView
		android:layout_width="24dp"
		android:layout_height="24dp"
		android:contentDescription="@string/shared_string_search"
		android:src="@drawable/ic_action_search_dark"
		app:tint="@color/google_maps_text_secondary" />

	<TextView
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_marginStart="14dp"
		android:layout_weight="1"
		android:ellipsize="end"
		android:singleLine="true"
		android:text="@string/flockfree_search_here"
		android:textColor="@color/google_maps_text_secondary"
		android:textSize="16sp" />

</LinearLayout>
